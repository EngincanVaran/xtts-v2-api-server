# Copy this file to .env and fill in your values.
# .env is gitignored — never commit secrets or local paths.

# Required — path to the local XTTS-v2 model directory.
MODEL_PATH=/path/to/xtts-v2

# GPU / worker topology
# NUM_GPUS=          # auto-detected if not set
# WORKERS_PER_GPU=1  # single int or comma-separated list e.g. "2,3,2"

# Language
# DEFAULT_LANGUAGE=tr

# Queue
# MAX_QUEUE_SIZE=100

# Job store
# JOB_TTL_SECONDS=300

# Directories
# SPEAKERS_DIR=./speakers
# OUTPUTS_DIR=./outputs

# Audio
# MAX_TEXT_LENGTH=5000
# SAMPLE_RATE=24000

# Server
# LOG_LEVEL=INFO
# HOST=0.0.0.0
# PORT=8000
