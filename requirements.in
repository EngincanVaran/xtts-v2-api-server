# -----------------------------------------------------------------------
# pip-tools workflow
# -----------------------------------------------------------------------
# This file lists DIRECT dependencies only — unpinned or loosely pinned.
# Do NOT edit requirements.txt by hand; it is generated by pip-compile.
#
# To regenerate the pinned lockfile:
#   pip install pip-tools
#   pip-compile requirements.in -o requirements.txt
#
# To add a new dependency:
#   1. Add it here (requirements.in)
#   2. Run: pip-compile requirements.in -o requirements.txt
#   3. Commit both files together
#
# To upgrade all pins:
#   pip-compile --upgrade requirements.in -o requirements.txt
# -----------------------------------------------------------------------

# Web framework
fastapi
uvicorn[standard]
python-multipart

# TTS model
coqui-tts

# Deep learning
torch
torchaudio

# Audio I/O and conversion
soundfile
pydub

# Settings management
pydantic-settings

# Numerical
numpy

# llvmlite 0.47 has no pre-built wheel for Intel Mac Python 3.11 and requires
# building from source against a specific LLVM version. Pin to the latest
# version that ships a pre-built wheel for this platform.
llvmlite==0.45.1       # last stable release with a pre-built wheel for Intel Mac Python 3.11
numba>=0.60,<0.63      # 0.62.x supports llvmlite 0.45.x
